{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@open/services": ["../services/src/index.ts"]
    },
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "rootDir": "../"
  },
  "include": ["src/**/*", "bin/**/*"]
}