{
  "name": "@open/services",
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts",
    "dev": "tsup --watch src/index.ts",
    "test": "vitest",
    "test:unit": "vitest run --config vitest.config.ts --exclude tests/integration/**",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.6.0",
    "bignumber.js": "^9.1.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
