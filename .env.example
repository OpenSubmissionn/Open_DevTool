# Helius API — get a key at https://dev.helius.xyz
HELIUS_API_KEY=

# Colosseum Copilot (optional) — for startup research skill
# Get a PAT at https://arena.colosseum.org/copilot
COLOSSEUM_COPILOT_PAT=
COLOSSEUM_COPILOT_API_BASE=https://copilot.colosseum.com/api/v1

# QEDGen formal verification (optional) — requires qedgen CLI
# Get a key at https://console.mistral.ai
MISTRAL_API_KEY=

# TheGrid (optional) — for Colosseum project graph queries
# Get a key at https://thegrid.id
THEGRID_API_KEY=
THEGRID_GRAPHQL_ENDPOINT=https://beta.node.thegrid.id/graphql

# QuickNode (optional) — for QuickNode RPC/Streams/DAS
# Get endpoints at https://www.quicknode.com
QUICKNODE_RPC_URL=
QUICKNODE_WSS_URL=
QUICKNODE_API_KEY=

# X/Twitter (optional) — for CT alpha research skill
# Get a bearer token at https://developer.x.com
X_BEARER_TOKEN=

# DFlow (optional) — for DFlow order flow integration
DFLOW_API_KEY=

# OPEN AI Recommendations
#
# Pick ONE of these to get AI-generated optimization suggestions:
#
#   Option 1 (FREE, recommended): GROQ_API_KEY
#     → Get a key at https://console.groq.com/keys (no credit card needed)
#     → Uses Llama 3.3 70B, ~30 req/min free tier
#
#   Option 2 (paid):              ANTHROPIC_API_KEY
#     → Get a key at https://console.anthropic.com (requires $5 top-up to activate)
#     → Uses Claude Sonnet, ~$0.003 per analysis
#
# Without either, the CLI still works — it just shows rule-based insights only.
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Advanced overrides (optional):
#   MCP_ENDPOINT_URL=https://your-host/insights   → POST payload to a custom service instead of calling an LLM directly
#   MCP_DISABLED=1                                → skip AI entirely (rule-based only)
#   MCP_MODEL=<model-id>                          → override the default model for whichever provider is active
MCP_ENDPOINT_URL=
MCP_DISABLED=
MCP_MODEL=
