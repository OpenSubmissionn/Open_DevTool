{
  "name": "open",
  "version": "1.0.0",
  "description": "CLI debugger visual para transações Solana",
  "main": "index.js",
  "scripts": {
    "cli": "tsx cli/bin/open.ts",
    "dev": "npm run dev -w cli",
    "build": "npm run build --workspaces",
    "test": "vitest",
    "test:unit": "npm run test:unit --workspace @open/services",
    "test:integration": "npm run test:integration --workspace @open/services",
    "test:all": "npm run test:unit && npm run test:integration",
    "coverage": "npm run coverage --workspace @open/services",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "validate:benchmarks": "tsx scripts/validate-benchmarks.ts",
    "validate:decoders": "tsx scripts/validate-decoders.ts",
    "bench:latency": "tsx scripts/latency-benchmark.ts"
  },
  "keywords": [],
  "author": "Nicole",
  "license": "ISC",
  "workspaces": [
    "cli",
    "services",
    "scripts"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "ink": "^3.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "yoga-layout": "^2.0.0"
  }
}
